# ── Database ──────────────────────────────────────────────────────────────────
# SQLAlchemy connection string. SQLite is used by default.
DATABASE_URL=sqlite:///./postpilot.db

# ── Authentication ────────────────────────────────────────────────────────────
# Long random string used to sign JWT tokens. Never commit the real value.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-this-to-a-long-random-string

JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# ── Encryption ────────────────────────────────────────────────────────────────
# Fernet symmetric key for API key encryption at rest (AES-128-CBC + HMAC-SHA256).
# Generate once and keep:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If blank, a key is auto-generated on startup (not suitable for production).
FERNET_KEY=

# ── File uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ── CORS ──────────────────────────────────────────────────────────────────────
# localhost:5173 is always allowed. Add extra origins here (comma-separated)
# for production deployments, e.g. your Vercel/Netlify URL.
# EXTRA_CORS_ORIGINS=https://your-frontend.example.com

# ── URLs ──────────────────────────────────────────────────────────────────────
# Used for OAuth callback redirects back to the frontend
FRONTEND_URL=https://postp.tabcrypt.in

# ── LinkedIn OAuth ─────────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://postp.tabcrypt.in/api/oauth/linkedin/callback

# ── Reddit OAuth ───────────────────────────────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REDIRECT_URI=https://postp.tabcrypt.in/api/oauth/reddit/callback
